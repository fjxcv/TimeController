<ui:Page x:Class="TimeController.Views.Review.ReviewView_everyday"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:local="clr-namespace:TimeController.Converters"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:TimeController.ViewModels"
        mc:Ignorable="d" 
        Title="ReviewView_everyday" d:DesignHeight="764" d:DesignWidth="1104">
 
    <!--<ui:Page.DataContext>
        <vm:ReviewViewModel_everyday />
    </ui:Page.DataContext>-->


    <ui:Page.Resources>
        <local:PostponeTextConverter x:Key="PostponeTextConverter"/>
        <local:AbandonTextConverter x:Key="AbandonTextConverter"/>
        <local:PostponeEnabledConverter x:Key="PostponeEnabledConverter"/>
        <local:AbandonEnabledConverter x:Key="AbandonEnabledConverter"/>
        <local:BoolToTimeTextConverter x:Key="BoolToTimeTextConverter"/>
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- 每日复盘按钮样式 -->
        <Style x:Key="EverydayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    CornerRadius="20"
                    Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="True">
                    <Setter Property="Background" Value="#cbf1f5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <!-- 本周复盘按钮样式 -->
        <Style x:Key="EveryweekButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    CornerRadius="20"
                    Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="False">
                    <Setter Property="Background" Value="#cbf1f5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:Page.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题和按钮 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="强目标模式" 
                      HorizontalAlignment="Left" 
                      VerticalAlignment="Top" 
                      FontSize="40" 
                      FontWeight="Bold" 
                      Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" 
                      Margin="20,20,600,0"/>
            <Button x:Name="Button1" 
                    Command="{Binding NavigateToEverydayCommand}" 
                    Content="每日复盘" 
                    IsEnabled="True" 
                    Padding="10" 
                    FontSize="24" 
                    Margin="0,0,20,0"
                    Style="{StaticResource EverydayButtonStyle}" 
                    Height="50"/>
            <Button x:Name="Button2" 
                    Command="{Binding NavigateToEveryweekCommand}" 
                    Content="本周复盘" 
                    IsEnabled="True" 
                    Padding="10" 
                    FontSize="24"
                    Style="{StaticResource EveryweekButtonStyle}" 
                    Height="50"/>
        </StackPanel>

        <!-- 日期选择器 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <DatePicker x:Name="datePicker" 
                       IsEnabled="True"
                       ui:ControlHelper.Header=""
                       ui:ControlHelper.PlaceholderText=""
                       ui:ControlHelper.Description=""
                       IsTodayHighlighted="True" 
                       IsDropDownOpen="False" 
                       Height="50" 
                       FontFamily="Yu Gothic UI Semibold" 
                       FontSize="18" 
                       FontWeight="Bold"
                       SelectedDate="{Binding SelectedDate}"/>
        </StackPanel>

        <!-- 主要内容区域 -->
        <Grid Grid.Row="2" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧今日任务区域 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="今日任务" 
                          FontSize="30" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center"
                          Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 已完成任务 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="✔ 已完成" 
                                 FontSize="24" 
                                 FontWeight="Bold" 
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding CompletedTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5" 
                                            CornerRadius="8" 
                                            Padding="10" 
                                            Margin="0,5">
                                        <TextBlock Text="{Binding Name}" 
                                                 FontSize="18"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 未完成任务 -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="❌ 未完成" 
                                 FontSize="24" 
                                 FontWeight="Bold" 
                                 HorizontalAlignment="Center"
                                 Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding UncompletedTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F5F5F5" 
                                            CornerRadius="8" 
                                            Padding="10" 
                                            Margin="0,5">
                                        <TextBlock Text="{Binding Name}" 
                                                 FontSize="18"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- 右侧未处理任务区域 -->
            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding PendingTasksCount, StringFormat='⏰ 等待处理的任务（共 {0} 项）'}" 
                          FontSize="20" 
                          FontWeight="Bold" 
                          HorizontalAlignment="Center"
                          Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding PendingTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F5F5F5" 
                                        CornerRadius="8" 
                                        Padding="15" 
                                        Margin="0,5">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" 
                                                 Text="{Binding PlannedDate, StringFormat='🗓 {0:yyyy-MM-dd}'}" 
                                                 FontSize="14" 
                                                 Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="1" 
                                                 Text="{Binding Name}" 
                                                 FontSize="18" 
                                                 FontWeight="Bold" 
                                                 Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="2" 
                                                 Text="{Binding IsAllDay, Converter={StaticResource BoolToTimeTextConverter}}" 
                                                 FontSize="14" 
                                                 Margin="0,0,0,10"/>

                                        <StackPanel Grid.Row="3" 
                                                  Orientation="Horizontal" 
                                                  HorizontalAlignment="Right">
                                            <Button Content="{Binding Status, Converter={StaticResource PostponeTextConverter}}"  
                                                    Click="PostponeButton_Click"
                                                    IsEnabled="{Binding Status, Converter={StaticResource PostponeEnabledConverter}}"
                                                    Margin="0,0,10,0"
                                                    />
                                            <Button Content="{Binding Status, Converter={StaticResource AbandonTextConverter}}"  
                                                    Click="AbandonButton_Click"
                                                    IsEnabled="{Binding Status, Converter={StaticResource AbandonEnabledConverter}}"
                                                    />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 底部提示栏 -->
        <Border Grid.Row="3" 
                Background="#FFF3CD" 
                BorderBrush="#FFEEBA" 
                BorderThickness="1" 
                CornerRadius="4" 
                Margin="20,0,20,20" 
                Padding="15"
                Visibility="{Binding PendingTasksCount, Converter={StaticResource CountToVisibilityConverter}}">
            <TextBlock Text="{Binding PendingTasksCount, StringFormat='🎯 你还有 {0} 项过期任务未处理，建议尽快处理以保持计划清晰~'}" 
                      FontSize="16"/>
        </Border>
    </Grid>
</ui:Page>
