<ui:Page x:Class="TimeController.Views.Review.ReviewView_everyweek"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TimeController.Views.Review"
      mc:Ignorable="d" 
      d:DesignHeight="764" d:DesignWidth="1104"
      Title="ReviewView_everyweek">


    <Page.Resources>
        <!-- 每日复盘按钮样式 -->
        <Style x:Key="EverydayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="20"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="True">
                    <Setter Property="Background" Value="#cbf1f5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <!-- 本周复盘按钮样式 -->
        <Style x:Key="EveryweekButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="20"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="False">
                    <Setter Property="Background" Value="#cbf1f5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
    </Page.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Text="强目标模式" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top" 
                FontSize="40" 
                FontWeight="Bold" 
                Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" 
                Margin="20,20,600,0"/>
            <Button x:Name="Button1" 
                    Command="{Binding NavigateToEverydayCommand}" 
                    Content="每日复盘" 
                    IsEnabled="True" 
                    Padding="10" 
                    FontSize="24" 
                    Margin="0,0,20,0"
                    Style="{StaticResource EverydayButtonStyle}" Height="50"/>
            <Button x:Name="Button2" 
                    Command="{Binding NavigateToEveryweekCommand}" 
                    Content="本周复盘" 
                    IsEnabled="True" 
                    Padding="10" 
                    FontSize="24"
                    Style="{StaticResource EveryweekButtonStyle}" Height="50"/>
        </StackPanel>
    </Grid>
</ui:Page>
