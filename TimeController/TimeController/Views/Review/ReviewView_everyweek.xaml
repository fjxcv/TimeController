<ui:Page x:Class="TimeController.Views.Review.ReviewView_everyweek"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TimeController.Views.Review"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      mc:Ignorable="d" 
      d:DesignHeight="764" d:DesignWidth="1104"
      Title="ReviewView_everyweek">


    <ui:Page.Resources>

        <!-- 复盘卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="166"/>
        </Style>

        <!--定义通用按钮样式-->
        <Style x:Key="BaseReviewButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- 每日复盘按钮样式 -->
        <Style x:Key="EverydayButtonStyle" TargetType="Button">
            <!-- 基础外观设置 -->
            <Setter Property="Background" Value="Transparent"/>
            
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">       
                            <!-- ✅ 让文字和边框有空隙 -->
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>

                </Setter.Value>
            </Setter>

            <!-- ✅ 高亮激活态 -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="True">
                    <Setter Property="Background" Value="#00BFA5"/>
                    <!-- 高亮色 -->
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>



        <!-- 本周复盘按钮样式 -->
        <Style x:Key="EveryweekButtonStyle" TargetType="Button">
            <!-- 和 Everyday 样式一样的结构 -->
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- ✅ 每周按钮只在 IsEverydayPage 为 false 时高亮 -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEverydayPage}" Value="False">
                    <Setter Property="Background" Value="#00BFA5"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>




        <!--滚动卡片-->
        <Style x:Key="ListItemBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="5,8"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
    </ui:Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        
        <!--顶部区域-->
        <Grid Grid.Row="0" Margin="20,10,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- 左：标题 -->
                <ColumnDefinition Width="Auto"/>
                <!-- 右：按钮组 -->
            </Grid.ColumnDefinitions>

            <!-- 左边：标题 -->
            <TextBlock Text="每周复盘"
               FontSize="36"
               FontWeight="Bold"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"/>

            <!-- 右边：切换按钮（样式与每日复盘一致） -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Right">
                <Button Content="每日复盘"
                FontSize="18"
                Command="{Binding NavigateToEverydayCommand}"
                Style="{StaticResource EverydayButtonStyle}"
                Margin="0,0,15,0"

                />
                
                <Button Content="每周复盘"
                FontSize="18"

                Command="{Binding NavigateToEveryweekCommand}"
                Style="{StaticResource EveryweekButtonStyle}"
                />
            </StackPanel>
        </Grid>

        <TextBlock Text="{Binding CurrentWeekRangeText}" Grid.Row="1"
           FontSize="16"
           Foreground="Gray"
           HorizontalAlignment="Center"
           Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Width="1104">

            <!-- 中间部分带背景、圆角 -->
            <Border CornerRadius="15" Padding="10,5" Background="#80AAAAAA" Margin="375,0,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&lt;" Command="{Binding PreviousWeekCommand}" Margin="5,0"/>
                    <TextBlock Text="{Binding CurrentWeekText}" FontWeight="Bold" Margin="10,0" FontSize="24"/>
                    <Button Content="&gt;" Command="{Binding NextWeekCommand}" Margin="5,0"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <Grid Grid.Row="3" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 复盘卡片区域 -->
            <ItemsControl ItemsSource="{Binding WeeklyReviewCards}" Margin="0,0,20,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- 彩色条 -->
                                <Border Background="{Binding AccentColor}" Grid.Column="0" />

                                <StackPanel Grid.Column="1" Margin="12,8,10,8">
                                <!-- 图标 -->
                                <TextBlock Text="{Binding Icon}" FontSize="20" Opacity="0.7" Margin="0,0,0,6"/>

                                <!--复盘标题-->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#222"
                                           Margin="0,0,0,15"/>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="18"
                                           Foreground="#444"
                                           TextWrapping="Wrap"/>

                            </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 右边：折线图和被推迟/放弃的任务列表 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 折线图 -->
                <lvc:CartesianChart
                    Series="{Binding Series}" 
                    XAxes="{Binding XAxes}" 
                    YAxes="{Binding YAxes}"
                    TooltipTextPaint="{Binding TooltipTextPaint}"
                    Height="300" Margin="0,0,0,10" Grid.Row="0"/>

                <StackPanel  Grid.Row="1">
                <TextBlock Text="本周被推迟/放弃的任务" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- 如果有任务就显示列表 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                    <ItemsControl ItemsSource="{Binding SkippedTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                    <Border Style="{StaticResource ListItemBorderStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                        <TextBlock Text="{Binding Name}" Width="200" FontSize="18" Margin="20,0,0,0"/>
                                            <TextBlock Text="{Binding StatusShownText}" Margin="100,0,0,0" HorizontalAlignment="Right" FontSize="18"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                    <!--如果没任务就显示提示 -->
                    <TextBlock Text="🎉 本周没有被推迟或放弃的任务"
                               FontStyle="Italic"
                               Foreground="Gray"
                               HorizontalAlignment="Center">    
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSkippedTasks}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>


                </StackPanel>
                
            </Grid>

        </Grid>

    </Grid>
</ui:Page>
