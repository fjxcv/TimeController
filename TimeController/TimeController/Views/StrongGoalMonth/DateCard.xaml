<UserControl x:Class="TimeController.Views.StrongGoalMonth.DateCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
             mc:Ignorable="d"
    <Border x:Name="CardBorder"
            BorderThickness="1"
            CornerRadius="8"
            Margin="4"
            Cursor="Hand"
            MouseLeftButtonUp="Border_MouseLeftButtonUp">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsToday, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    </DataTrigger>

                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E4E4E4"/>
                    </Trigger>
                    
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- ������ʾ���� -->
            <TextBlock x:Name="DateText"
                      Grid.Row="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0"
                      FontSize="20"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                <!-- ����������չ������ʾ������ -->
                <StackPanel>
                    <TextBlock Text="�����б�" 
                             FontWeight="Bold" 
                             Margin="0,10,0,5"/>
                    <!-- ������������������б���������� -->
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
    
    
</UserControl>