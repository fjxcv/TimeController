<UserControl x:Class="TimeController.Views.StrongGoalMonth.DateCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="100">
    <Border x:Name="CardBorder"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            CornerRadius="8"
            Margin="4"
            Cursor="Hand"
            MouseLeftButtonUp="Border_MouseLeftButtonUp">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#F8F8F8"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsToday, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter Property="Background" Value="#CCE4FF"/>
                    </DataTrigger>

                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E4E4E4"/>
                    </Trigger>
                    
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="DateText"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,5,0,0"
                      FontSize="20"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="60">
                <ItemsControl
                          ItemsSource="{Binding DisplayedTasks, RelativeSource={RelativeSource AncestorType=UserControl}}">
                
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   FontSize="12"
                                   Margin="2,0"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   MaxWidth="{Binding ActualWidth, ElementName=CardBorder}"
                                   ToolTip="{Binding Name}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Button Grid.Row="2"
                    Margin="0,2,0,2"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ToggleExpand"
                    Visibility="{Binding HasMoreTasks, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="&#x25BC;"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Content" Value="&#x25B2;"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>


            <!-- Popup showing additional task details -->
            <Popup x:Name="TaskPopup"
           PlacementTarget="{Binding ElementName=CardBorder}"
           Placement="AbsolutePoint"
           HorizontalOffset="0"
           VerticalOffset="8"
           AllowsTransparency="True"
           StaysOpen="False"
           PopupAnimation="Fade"
           DataContext="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}"
           Closed="TaskPopup_Closed">
                <Border Background="#CCFFFFFF"
                CornerRadius="6"
                Padding="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.25"/>
                    </Border.Effect>
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12" Margin="2,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Popup>


        </Grid>
    </Border>
    
    
</UserControl>