<Window x:Class="TimeController.Views.AddTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        Title="添加任务" Height="350" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="任务名称" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Height="30" MaxLength="15"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="任务备注" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1" Height="30" MaxLength="30" Margin="0,10,0,0"
                 Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" />

        <TextBlock Text="任务类型" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                  SelectedValue="{Binding Type}" SelectedValuePath="Content">
            <ComboBoxItem Content="未分类"/>
            <ComboBoxItem Content="学习学业"/>
            <ComboBoxItem Content="项目实践任务"/>
            <ComboBoxItem Content="日常任务"/>
            <ComboBoxItem Content="自我提升"/>
            <ComboBoxItem Content="其它"/>
        </ComboBox>

        <TextBlock Text="时间段" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
            <ComboBox Width="90" ItemsSource="{Binding TimeOptions}" SelectedItem="{Binding StartTime}" IsEnabled="{Binding IsTimeSelectionEnabled}" />
            <TextBlock Text="—" VerticalAlignment="Center" Margin="10,0"/>
            <ComboBox Width="90" ItemsSource="{Binding TimeOptions}" SelectedItem="{Binding EndTime}" IsEnabled="{Binding IsTimeSelectionEnabled}" />
        </StackPanel>

        <CheckBox Content="全天任务" Grid.Row="4" Grid.Column="0" Margin="40,10,0,0" Grid.ColumnSpan="2"
                  IsChecked="{Binding IsAllDay}" />

        <CheckBox Content="开启提醒" Grid.Row="4" Grid.Column="1" Margin="125,10,0,0"
                  IsChecked="{Binding IsReminderEnabled}" />

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="取消" Width="80" Margin="0,0,20,0" Click="Cancel_Click"/>
            <Button Content="保存" Width="80" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
