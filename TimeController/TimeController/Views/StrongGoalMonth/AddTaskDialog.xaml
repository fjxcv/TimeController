<Window x:Class="TimeController.Views.AddTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="添加任务" Height="470" Width="450">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 任务名称 -->
            <RowDefinition Height="Auto"/>
            <!-- 时间段提示 -->
            <RowDefinition Height="Auto"/>
            <!-- 任务备注 -->
            <RowDefinition Height="Auto"/>
            <!-- 任务类型 -->
            <RowDefinition Height="Auto"/>
            <!-- 时间段 -->
            <RowDefinition Height="Auto"/>
            <!-- 全天任务和提醒 -->
            <RowDefinition Height="*"/>
            <!-- 按钮和底部空间 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 任务名称 -->
        <TextBlock Text="任务名称" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Height="30" MaxLength="15" Width="300" HorizontalAlignment="Left"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

        <!-- 时间段提示信息 - 移动到任务名称下方 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="80,2,0,5"
                Text="{Binding TimePeriodHint}"
                Foreground="#0078D4"
                FontSize="11"
                FontFamily="{StaticResource HOS_Sans_Bold}"
                TextWrapping="Wrap"
                HorizontalAlignment="Left"
                Visibility="{Binding HasTimePeriodHint, Converter={StaticResource BoolToVisibility}}"/>

        <!-- 任务备注 -->
        <TextBlock Text="任务备注" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <Grid Grid.Row="2"
              Grid.Column="1"
              Height="80"
              Margin="0,10,0,0"
              Width="300"
              HorizontalAlignment="Left"
              >

            <!-- TextBox 输入框 -->
            <TextBox
                x:Name="NoteBox"
                Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                MaxLength="200"
                VerticalScrollBarVisibility="Auto"
                Padding="4,4,40,4"
                VerticalContentAlignment="Top"
                />

            <!-- 悬浮字数提示 -->
            <TextBlock
                Text="{Binding NoteCharHint}"
                FontSize="12"
                Foreground="Gray"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,4,2"
                Background="#FFFFFFCC"
                />
        </Grid>

        <!-- 任务类型 -->
        <TextBlock Text="任务类型" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,10,0,0"
                  SelectedValue="{Binding Type}" SelectedValuePath="Content">
            <ComboBoxItem Content="未分类"/>
            <ComboBoxItem Content="学习学业"/>
            <ComboBoxItem Content="项目实践任务"/>
            <ComboBoxItem Content="日常任务"/>
            <ComboBoxItem Content="自我提升"/>
            <ComboBoxItem Content="其它"/>
        </ComboBox>

        <!-- 时间段 -->
        <TextBlock Text="时间段" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0"/>

        <!-- 时间选择器分三行显示 -->
        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
            <!-- 开始时间 -->
            <ui:TimePicker 
                SelectedDateTime="{Binding StartTimeWrapper, Mode=TwoWay}" 
                IsEnabled="{Binding IsTimeSelectionEnabled}" />


            <TextBlock Text="—" 
               FontSize="18" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"
               Margin="0,0,80,5"/>

            <!-- 结束时间 -->
            <ui:TimePicker 
                 SelectedDateTime="{Binding EndTimeWrapper, Mode=TwoWay}" 
                IsEnabled="{Binding IsTimeSelectionEnabled}"/>


            <!-- 提示占位但默认隐藏（不会闪跳） -->
            <TextBlock
                Text="{Binding TimeError}"
                Foreground="Red"
                FontSize="12"
                Margin="50,4,0,0"
                Visibility="{Binding HasTimeError, Converter={StaticResource BoolToHiddenConverter}}" />
        </StackPanel>

        <!-- 全天任务和提醒 -->
        <CheckBox Content="全天任务" Grid.Row="5" Grid.Column="0" Margin="80,0,0,0" Grid.ColumnSpan="2"
                  IsChecked="{Binding IsAllDay}" />

        <CheckBox Content="开启提醒" Grid.Row="5" Grid.Column="1" Margin="155,0,0,0"
                  IsChecked="{Binding IsReminderEnabled}" />

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="取消" Width="80" Margin="0,0,20,0" Click="Cancel_Click"/>
            <Button Content="保存" Width="80" IsEnabled="{Binding IsTimeValid}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
