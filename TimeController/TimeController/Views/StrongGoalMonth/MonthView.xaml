<ui:Page x:Class="TimeController.Views.StrongGoalMonth.MonthView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
      xmlns:local="clr-namespace:TimeController.Views.StrongGoalMonth"
      xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:vm="clr-namespace:TimeController.ViewModels"
      xmlns:conv="clr-namespace:TimeController.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MonthView">


    <ui:Page.Resources>
        <conv:DateTasksLookupConverter x:Key="DateTasksLookupConverter" />
        <conv:DateTasksMultiConverter x:Key="DateTasksMultiConverter" />
    </ui:Page.Resources>


    <!-- 主网格布局 -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <!-- 顶部标题栏 -->
            <RowDefinition Height="Auto"/>
            <!-- 年月导航 -->
            <RowDefinition Height="Auto"/>
            <!-- 星期栏 -->
            <RowDefinition Height="*"/>
            <!-- 日历内容区域（自动填充剩余空间） -->
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,0" Height="35.78">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="87*"/>
                <ColumnDefinition Width="713*"/>
            </Grid.ColumnDefinitions>
            <!-- 主标题 -->
            <TextBlock Text="强目标模式" 
                     FontSize="24" 
                     FontWeight="Bold" 
                     VerticalAlignment="Center" 
                     HorizontalAlignment="Left" 
                     Margin="40,0,0,0" Grid.ColumnSpan="2"/>

            <!-- 进入复盘 -->
            <Button Content="进入复盘"
                   Command="{Binding ReviewCommand}"
                   Height="35.78"
                   Padding="16,8"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,40,0" Grid.Column="1"/>
        </Grid>

        <!-- 年月导航栏 -->
        <Grid Grid.Row="1" 
      HorizontalAlignment="Center" 
      Margin="0,5,0,0"
      Width="600">
            <!-- 固定总宽度 -->
            <Grid.ColumnDefinitions>
                <!-- 年份部分 -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/>
                <!-- 年份和月份之间的总间距 -->

                <!-- 月份部分 -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <!-- 回到当前月份按钮 -->
            </Grid.ColumnDefinitions>

            <!-- 上一年按钮 -->
            <Button Command="{Binding PrevYearCommand}"
            Width="40"
            Height="40"
            Grid.Column="0">
                <uiControls:FontIcon Glyph="&#xE76B;" FontSize="16"/>
            </Button>

            <!-- 当前年份 -->
            <Border Background="#FFEBEBEB"
           CornerRadius="20"
           Padding="20,0"
           Grid.Column="2">
                <TextBlock Text="{Binding YearText}"
                   FontSize="24"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   MinWidth="80"/>
            </Border>

            <!-- 下一年按钮 -->
            <Button Command="{Binding NextYearCommand}"
            Width="40"
            Height="40"
            Grid.Column="4">
                <uiControls:FontIcon Glyph="&#xE76C;" FontSize="16"/>
            </Button>

            <!-- 上一月按钮 -->
            <Button Command="{Binding PrevMonthCommand}"
            Width="40"
            Height="40"
            Grid.Column="6">
                <uiControls:FontIcon Glyph="&#xE76B;" FontSize="16"/>
            </Button>

            <!-- 当前月份 -->
            <Border Background="#FFEBEBEB"
           CornerRadius="20"
           Padding="20,0"
           Grid.Column="8"
           HorizontalAlignment="Center">
                <TextBlock Text="{Binding MonthText}"
                   FontSize="24"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   MinWidth="40"/>
            </Border>

            <!-- 下一月按钮 -->
            <Button Command="{Binding NextMonthCommand}"
            Width="40"
            Height="40"
            Grid.Column="10">
                <uiControls:FontIcon Glyph="&#xE76C;" FontSize="16"/>
            </Button>

            <!-- 回到当前月份按钮 -->
            <Button Command="{Binding GoToCurrentMonthCommand}"
            Width="40"
            Height="40"
            ToolTip="回到当前月份"
            Visibility="{Binding IsCurrentMonth, Converter={StaticResource InverseBoolToVisibilityConverter}}"
            Grid.Column="11"
            Margin="24,0,0,0">
                <!-- 保持与下一月按钮的间距一致 -->
                <uiControls:FontIcon Glyph="&#xE823;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- 星期栏 -->
        <Grid Grid.Row="2" Margin="40,30,40,0">
            <!-- 7列网格布局 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- 星期一到星期日 -->
            <TextBlock Text="一" Grid.Column="0" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="二" Grid.Column="1" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="三" Grid.Column="2" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="四" Grid.Column="3" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="五" Grid.Column="4" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="六" Grid.Column="5" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="日" Grid.Column="6" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold"/>
        </Grid>

        <!-- 日历内容区域（可滚动） -->
        <ScrollViewer x:Name="CalendarScrollViewer"
                      Grid.Row="3"
                      Margin="40,10,40,40"
                      ScrollChanged="CalendarScrollViewer_ScrollChanged">
            <!-- 使用ItemsControl显示日历天数 -->
            <ItemsControl ItemsSource="{Binding CalendarDays}">
                <!-- 使用7列的UniformGrid作为布局面板 -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- 每个项目的模板 - 使用DateCard控件 -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 绑定日期和点击命令 -->
                        <local:DateCard Date="{Binding}" Margin="2"
                                       Command="{Binding DataContext.DateClickCommand,
                                               RelativeSource={RelativeSource AncestorType=ui:Page}}">
                            <local:DateCard.Tasks>
                                <MultiBinding Converter="{StaticResource DateTasksMultiConverter}">
                                    <Binding Path="DataContext.TasksByDate" RelativeSource="{RelativeSource AncestorType=ui:Page}"/>
                                    <Binding />
                                </MultiBinding>
                            </local:DateCard.Tasks>
                            
                            
                            <!-- 设置样式 -->
                            <local:DateCard.Style>
                                <Style TargetType="local:DateCard">
                                    <!-- 日期为空则隐藏卡片 -->
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:DateCard.Style>
                        </local:DateCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</ui:Page>