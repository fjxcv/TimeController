<Window x:Class="TimeController.Views.StrongGoalMonth.TodayTasksReminderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeController.Views.StrongGoalMonth"
        xmlns:converters="clr-namespace:TimeController.Converters"
        mc:Ignorable="d"
        Title="今日任务提醒" 
        Height="400" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:TaskTimeConverter x:Key="TaskTimeConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="8" 
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" 
                            ShadowDepth="0" 
                            Opacity="0.2"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Background="#F5F5F5" 
                    CornerRadius="8,8,0,0" 
                    Padding="20,15">
                <TextBlock Text="今日任务提醒" 
                         FontSize="18" 
                         FontWeight="SemiBold"
                         Foreground="#333333"/>
            </Border>

            <!-- 任务列表 -->
            <ScrollViewer Grid.Row="1" 
                         Margin="20,10"
                         VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5" 
                Padding="15,10"
                Background="#F8F8F8"
                CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：任务名称和备注 -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                             FontSize="14"
                             FontWeight="Medium"
                             Foreground="#333333"/>
                                        <TextBlock Text="{Binding Note}" 
                             FontSize="12"
                             Foreground="#666666"
                             TextTrimming="CharacterEllipsis"
                             Margin="0,4,0,0"
                             Visibility="{Binding Note, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- 右侧：时间信息 -->
                                    <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="12"
                           Foreground="#888888">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource TaskTimeConverter}">
                                                <Binding Path="IsAllDay"/>
                                                <Binding Path="StartTime"/>
                                                <Binding Path="EndTime"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5" 
                    CornerRadius="0,0,8,8" 
                    Padding="20,15">
                <Button Content="知道了" 
                        Command="{Binding CloseCommand}"
                        Width="100"
                        Height="32"
                        Background="#0078D4"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#106EBE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window> 