<Window x:Class="TimeController.Views.Dialogs.PostponeDateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeController.Views.Dialogs"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Title="选择推迟日期" Height="300" Width="450">
    
    <StackPanel Margin="20" VerticalAlignment="Center">
       <TextBlock Text="请选择推迟到的日期：" FontSize="16" Margin="0,0,0,10"/>
       <DatePicker x:Name="DatePicker_Target" SelectedDate="{Binding SelectedDate}" DisplayDateStart="{x:Static sys:DateTime.Today}"/>
       <Button Content="确认" Width="80" Height="30" Margin="0,20,0,0" HorizontalAlignment="Center" Click="Confirm_Click"/>
    </StackPanel>
    
</Window>
