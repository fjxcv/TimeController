<ui:Page x:Class="TimeController.Views.CasualMode.CasualModeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TimeController.Views.CasualMode"
        xmlns:local1="clr-namespace:TimeController.ViewModels"
        xmlns:input="clr-namespace:System.Windows.Input;assembly=PresentationCore"
        mc:Ignorable="d"
        Title="" d:DesignHeight="800" d:DesignWidth="1104"
        MinHeight="600" MinWidth="800">

    <ui:Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- 按钮样式 -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#20000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 自定义进度条样式 -->
        <Style x:Key="CustomProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <Grid>
                                <Border x:Name="PART_Track" CornerRadius="10" Background="#E0E0E0"/>
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#424242" Offset="0"/>
                                            <GradientStop Color="#424242" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 奖励弹窗样式 -->
        <Style x:Key="RewardPopupStyle" TargetType="Popup">
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="PlacementTarget" Value="{Binding ElementName=RewardButton}"/>
            <Setter Property="HorizontalOffset" Value="10"/>
            <Setter Property="VerticalOffset" Value="-100"/>
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="StaysOpen" Value="False"/>
            <Setter Property="PopupAnimation" Value="Slide"/>
        </Style>
    </ui:Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" MinWidth="400"/>
            <ColumnDefinition Width="2*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主板块 -->
        <StackPanel Grid.Column="0" Margin="30,20,20,20">
            <!-- 顶部进度条区域 -->
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,10,0,20">
                    <TextBlock Text="奖励进度" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ProgressBar Style="{StaticResource CustomProgressBar}"
                                 Width="Auto" MinWidth="450" Margin="16,0,8,0"
                                 VerticalAlignment="Center" Value="{Binding Progress}" Maximum="4"/>
                    <Button x:Name="RewardButton" Width="36" Height="28" Margin="0,0,0,0"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ToggleRewardPopupCommand}">
                        <uiControls:FontIcon Glyph="&#xE735;" FontSize="20" Foreground="#FFD700"/>
                    </Button>
                </StackPanel>
                <Popup x:Name="RewardPopup"
                       Style="{StaticResource RewardPopupStyle}"
                       IsOpen="{Binding IsRewardPopupOpen, Mode=TwoWay}"
                       StaysOpen="False"
                       Focusable="True"
                       FocusManager.IsFocusScope="True"
                       FocusManager.FocusedElement="{Binding ElementName=RewardTaskInput}">
                    <Border Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Width="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#20000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 标题栏 -->
                            <Border Background="#FFD700" CornerRadius="8,8,0,0" Padding="10,8">
                                <TextBlock Text="奖励任务" Foreground="White" FontWeight="Bold"/>
                            </Border>

                            <!-- 奖励任务列表 -->
                            <ListView Grid.Row="1" ItemsSource="{Binding RewardTasks}" Margin="10" MaxHeight="200">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=TwoWay}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="5,0,0,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="×" Width="20" Height="20"
                                                      Command="{Binding DataContext.DeleteRewardTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                                      CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- 添加新任务 -->
                            <Grid Grid.Row="2" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="RewardTaskInput"
                                 Text="{Binding NewRewardTaskText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Height="28"
                                 Focusable="True" IsTabStop="True">
                                    <!-- Removed the invalid InputMethod.Placement property -->
                                </TextBox>

                                <Button Grid.Column="1" Content="添加"
                                          Command="{Binding AddRewardTaskCommand}"
                                          Style="{StaticResource IconButtonStyle}"
                                          Margin="5,0,0,0"/>
                            </Grid>

                            <!-- 小箭头 -->
                            <Path Grid.Row="0" Grid.RowSpan="3"
                                      Data="M 0,0 L 10,10 L 0,20 Z"
                                      Fill="White" Stroke="#E0E0E0" StrokeThickness="1"
                                      HorizontalAlignment="Left" Margin="-10,50,0,0"/>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- 四个模块 2x2 -->
            <Grid Margin="0,0,0,0" Height="589">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="150"/>
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- 自我滋养 -->
                <Border Grid.Row="0" Grid.Column="0" Background="#D6F3ED" Margin="8">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleInputVisibilityCommand}"
                                      CommandParameter="{Binding Modules[0]}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="自我滋养" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" 
                                   HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <!-- 任务列表 -->
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[0].Tasks}" 
                                  Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                              VerticalAlignment="Center"/>

                                        <!-- 显示模式（默认） -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.StartEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 编辑模式 -->
                                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                         Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter"
                                                            Command="{Binding DataContext.EndEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                            CommandParameter="{Binding}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>

                                        <!-- 删除按钮 -->
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                        Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                        CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- 悬停时显示编辑提示 -->
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="ToolTip" Value="双击编辑"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                     <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                     <Setter Property="VerticalContentAlignment" Value="Center"/>
                                     <Setter Property="Margin" Value="0,2"/>
                                     <!-- 默认选中背景和边框（您可以根据需要调整颜色） -->
                                     <Setter Property="Template">
                                         <Setter.Value>
                                             <ControlTemplate TargetType="ListViewItem">
                                                 <Border x:Name="Border"
                                                         Padding="{TemplateBinding Padding}"
                                                         Margin="{TemplateBinding Margin}"
                                                         Background="{TemplateBinding Background}"
                                                         BorderBrush="{TemplateBinding BorderBrush}"
                                                         BorderThickness="{TemplateBinding BorderThickness}">
                                                     <VisualStateManager.VisualStateGroups>
                                                         <VisualStateGroup x:Name="SelectionStates">
                                                             <VisualState x:Name="Unselected"/>
                                                             <VisualState x:Name="Selected">
                                                                 <Storyboard>
                                                                     <ColorAnimationUsingKeyFrames Storyboard.TargetName="Border" Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)">
                                                                         <EasingColorKeyFrame KeyTime="0" Value="#E0F2F7"/> <!-- 选中时的背景色 -->
                                                                     </ColorAnimationUsingKeyFrames>
                                                                 </Storyboard>
                                                             </VisualState>
                                                             <VisualState x:Name="SelectedUnfocused">
                                                                  <Storyboard>
                                                                     <ColorAnimationUsingKeyFrames Storyboard.TargetName="Border" Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)">
                                                                         <EasingColorKeyFrame KeyTime="0" Value="#E0F2F7"/> <!-- 失去焦点时的选中背景色 -->
                                                                     </ColorAnimationUsingKeyFrames>
                                                                 </Storyboard>
                                                             </VisualState>
                                                         </VisualStateGroup>
                                                     </VisualStateManager.VisualStateGroups>
                                                     <ContentPresenter/>
                                                 </Border>
                                             </ControlTemplate>
                                         </Setter.Value>
                                     </Setter>
                                     <Style.Triggers>
                                         <!-- 当IsSelected为True时应用选中样式 -->
                                         <Trigger Property="IsSelected" Value="True">
                                             <Setter Property="Background" Value="#E0F2F7"/> <!-- 选中背景色 -->
                                             <!-- 如果有蓝色竖线，可能需要在这里或Template中控制其可见性 -->
                                         </Trigger>
                                         <!-- 当IsInputVisible为True时，隐藏选中样式 -->
                                         <DataTrigger Binding="{Binding DataContext.IsInputVisible, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}" Value="True">
                                             <Setter Property="Background" Value="Transparent"/>
                                             <!-- 移除蓝色竖线或其他选中指示 -->
                                         </DataTrigger>
                                         <!-- 当CurrentEditingTask不为null时，隐藏选中样式 -->
                                         <DataTrigger Binding="{Binding DataContext.CurrentEditingTask, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}" Value="{x:Null}">
                                             <Setter Property="Background" Value="Transparent"/>
                                             <!-- 移除蓝色竖线或其他选中指示 -->
                                         </DataTrigger>
                                     </Style.Triggers>
                                 </Style>
                             </ListView.ItemContainerStyle>
                        </ListView>
                        <!-- 新任务输入框（可见性绑定） -->
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[0].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding Modules[0].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding Modules[0]}"
                                     Margin="0,0,0,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TextBox}}}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 创造表达 -->
                <Border Grid.Row="0" Grid.Column="1" Background="#D6F3ED" Margin="8">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleInputVisibilityCommand}"
                                      CommandParameter="{Binding Modules[1]}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="创造表达" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[1].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.StartEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                         Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter"
                                                            Command="{Binding DataContext.EndEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                            CommandParameter="{Binding}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="ToolTip" Value="双击编辑"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[1].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding Modules[1].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding Modules[1]}"
                                     Margin="0,0,0,0" Height="32" VerticalAlignment="Bottom">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TextBox}}}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 生活杂务 -->
                <Border Grid.Row="1" Grid.Column="0" Background="#D6F3ED" Margin="8">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleInputVisibilityCommand}"
                                      CommandParameter="{Binding Modules[2]}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="生活杂务" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[2].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.StartEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                         Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter"
                                                            Command="{Binding DataContext.EndEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                            CommandParameter="{Binding}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="ToolTip" Value="双击编辑"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[2].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding Modules[2].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding Modules[2]}"
                                     Margin="0,0,0,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TextBox}}}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 人际连接 -->
                <Border Grid.Row="1" Grid.Column="1" Background="#D6F3ED" Margin="8">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleInputVisibilityCommand}"
                                      CommandParameter="{Binding Modules[3]}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="人际连接" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[3].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.StartEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                              CommandParameter="{Binding}"/>
                                            </TextBlock.InputBindings>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                         Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter"
                                                            Command="{Binding DataContext.EndEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                            CommandParameter="{Binding}"/>
                                            </TextBox.InputBindings>
                                        </TextBox>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="ToolTip" Value="双击编辑"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[3].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding Modules[3].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding Modules[3]}"
                                     Margin="0,0,0,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"
                                                Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TextBox}}}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <!-- 右侧板块（长期备忘） -->
        <StackPanel Grid.Column="1" Margin="0,20,30,20">
            <Border Background="#D6F3ED" Padding="16" MinHeight="200" Margin="0,0,0,16" Height="392">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ToggleInputVisibilityCommand}"
                                  CommandParameter="{Binding Modules[4]}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="长期备忘" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="center" Margin="0,0,0,0"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding Modules[4].Tasks}" Margin="10,10,10,10" Background="Transparent" BorderThickness="0">
                         <ListView.ItemTemplate>
                            <DataTemplate>
                                 <Grid>
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="30"/>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                     <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=TwoWay}" VerticalAlignment="Center"/>
                                     
                                     <!-- 显示模式（默认） -->
                                     <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                         <TextBlock.InputBindings>
                                             <MouseBinding MouseAction="LeftDoubleClick"
                                                           Command="{Binding DataContext.StartEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                           CommandParameter="{Binding}"/>
                                         </TextBlock.InputBindings>
                                         <TextBlock.Style>
                                             <Style TargetType="TextBlock">
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                         <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </TextBlock.Style>
                                     </TextBlock>

                                     <!-- 编辑模式 -->
                                     <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                      Margin="0,0,0,0" VerticalAlignment="Center">
                                         <TextBox.InputBindings>
                                             <KeyBinding Key="Enter"
                                                         Command="{Binding DataContext.EndEditTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                                         CommandParameter="{Binding}"/>
                                         </TextBox.InputBindings>
                                     </TextBox>

                                     <!-- 删除按钮 -->
                                     <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                             Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                             CommandParameter="{Binding}">
                                         <Button.Style>
                                             <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                 <Setter Property="Visibility" Value="Collapsed"/>
                                                 <Setter Property="FontSize" Value="18"/>
                                                 <Style.Triggers>
                                                     <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}}" Value="True">
                                                         <Setter Property="Visibility" Value="Visible"/>
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </Button.Style>
                                     </Button>

                                     <!-- 悬停时显示编辑提示 -->
                                     <Grid.Style>
                                         <Style TargetType="Grid">
                                             <Style.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter Property="ToolTip" Value="双击编辑"/>
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Grid.Style>
                                 </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <!-- 输入框 -->
                    <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[4].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                        <TextBox Text="{Binding Modules[4].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="{Binding Modules[4]}"
                                 Margin="0,0,0,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding DataContext.AddTaskCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ui:Page}}}"
                                            CommandParameter="{Binding Tag, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TextBox}}}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Grid>
            </Border>
            <!-- 本周复盘 -->
            <Border Background="#D6F3ED" Padding="16" MinHeight="200" Height="282">
                <TextBlock FontSize="20" FontWeight="Bold" Height="255" Text="&#x9;     本周复盘" />
            </Border>
        </StackPanel>
    </Grid>
</ui:Page>