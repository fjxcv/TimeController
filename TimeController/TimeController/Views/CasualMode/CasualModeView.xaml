<ui:Page x:Class="TimeController.Views.CasualMode.CasualModeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
         xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:local="clr-namespace:TimeController.Views.CasualMode" xmlns:local1="clr-namespace:TimeController.ViewModels"
         mc:Ignorable="d" 
 Title="" d:DesignHeight="800" d:DesignWidth="1104"
 MinHeight="600" MinWidth="800">
    <ui:Page.Resources>
        <!-- 布尔值到可见性的转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- 按钮样式 -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#20000000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 自定义进度条样式 -->
        <Style x:Key="CustomProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border 
                    Background="{TemplateBinding Background}"
                    CornerRadius="10">
                            <Grid>
                                <Border x:Name="PART_Track" CornerRadius="10" Background="#E0E0E0"/>
                                <Border x:Name="PART_Indicator" 
                                HorizontalAlignment="Left"
                                CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#424242" Offset="0"/>
                                            <GradientStop Color="#424242" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 奖励弹窗样式 -->
        <Style x:Key="RewardPopupStyle" TargetType="Popup">
            <Setter Property="Placement" Value="Right"/>
            <Setter Property="PlacementTarget" Value="{Binding ElementName=RewardButton}"/>
            <Setter Property="HorizontalOffset" Value="10"/>
            <Setter Property="VerticalOffset" Value="-100"/>
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="StaysOpen" Value="False"/>
            <!-- 确保弹窗内容正确渲染 -->
            <Setter Property="PopupAnimation" Value="Slide"/>
        </Style>
    </ui:Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" MinWidth="400"/>
            <ColumnDefinition Width="2*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主板块 -->
        <StackPanel Grid.Column="0" Margin="30,20,20,20">
            <!-- 顶部进度条区域 -->
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,20">
                    <TextBlock Text="本周进度" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ProgressBar 
                        Style="{StaticResource CustomProgressBar}" 
                        Width="Auto" 
                        MinWidth="450" 
                        Margin="16,0,8,0" 
                        VerticalAlignment="Center" 
                        Value="{Binding Progress}"/>
                    <Button x:Name="RewardButton"
                            Width="36"  
                            Height="28" 
                            Margin="0,0,0,0"  
                            VerticalAlignment="Center" 
                            Style="{StaticResource IconButtonStyle}"
                            Click="RewardButton_Click">
                        <uiControls:FontIcon Glyph="&#xE735;" FontSize="20" Foreground="#FFD700"/>
                    </Button>
                </StackPanel>
                <Popup x:Name="RewardPopup"
                       Style="{StaticResource RewardPopupStyle}">
                    <Border Background="White" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="8"
                            Width="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="#20000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 标题栏 -->
                            <Border Background="#FFD700" 
                                    CornerRadius="8,8,0,0" 
                                    Padding="10,8">
                                <TextBlock Text="奖励任务" 
                                         Foreground="White" 
                                         FontWeight="Bold"/>
                            </Border>

                            <!-- 任务列表 -->
                            <ListView Grid.Row="1" 
                                     ItemsSource="{Binding RewardTasks}"
                                     Margin="10"
                                     MaxHeight="200">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" 
                                                     IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" 
                                                     Text="{Binding Name}" 
                                                     Margin="5,0,0,0" 
                                                     VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="2" 
                                                    Content="×" 
                                                    Width="20" 
                                                    Height="20"
                                                    Command="{Binding DataContext.DeleteRewardTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- 添加新任务 -->
                            <Grid Grid.Row="2" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RewardTaskInput"
        Text="{Binding NewRewardTaskText, UpdateSourceTrigger=PropertyChanged}"
        KeyDown="RewardTaskTextBox_KeyDown"
        Margin="0,0,5,0"
        Focusable="True">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border 
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                                                            <!-- 确保 ScrollViewer 正确显示文本 -->
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="ToolTip" Value="输入奖励任务..."/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FFD700"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Grid.Column="1" 
                                        Content="添加" 
                                        Click="AddRewardTask_Click"
                                        Style="{StaticResource IconButtonStyle}"/>
                            </Grid>

                            <!-- 尖嘴符号 -->
                            <Path Grid.Row="0" 
                                  Grid.RowSpan="3"
                                  Data="M 0,0 L 10,10 L 0,20 Z" 
                                  Fill="White" 
                                  Stroke="#E0E0E0" 
                                  StrokeThickness="1"
                                  HorizontalAlignment="Left"
                                  Margin="-10,50,0,0"/>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>

            <!-- 四个模块 2x2 -->
            <Grid Margin="0,0,0,0" Height="589">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="150"/>
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- 自我滋养 -->
                <Border Grid.Row="0" Grid.Column="0" Background="#D6F3ED" Margin="8" MouseDown="SelfNourishBorder_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="161*"/>
                            <ColumnDefinition Width="166*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="自我滋养" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" 
                                   HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <!-- 任务列表 -->
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[0].Tasks}" 
                                  Margin="10,10,10,0" Background="Transparent" BorderThickness="0" 
                                  RenderTransformOrigin="0.521,0.862" 
                                  Grid.ColumnSpan="2" Height="234" VerticalAlignment="Top"
                                  PreviewMouseDoubleClick="ListViewItem_DoubleClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                              VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                        Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                        CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- 新任务输入框（可见性绑定） -->
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[0].IsInputVisible, Converter={StaticResource BoolToVisibility}}" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Modules[0].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="NewTaskTextBox_KeyDown"
                                 Tag="{Binding Modules[0]}"
                                 Margin="0,0,5,0" RenderTransformOrigin="0.507,0.969"/>
                            <Button Grid.Column="1" Content="×" Width="20" Height="20" FontSize="18" Margin="0,0,0,5"
                                Click="SelfNourishInputCancel_Click"
                                Style="{StaticResource IconButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 创造表达 -->
                <Border Grid.Row="0" Grid.Column="1" Background="#D6F3ED" Margin="8" MouseDown="CreateExpressionBorder_MouseDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="创造表达" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[1].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- 新任务输入框（可见性绑定） -->
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[1].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Modules[1].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="NewTaskTextBox_KeyDown"
                                     Tag="{Binding Modules[1]}"
                                     Margin="0,0,5,0" Height="32" VerticalAlignment="Bottom"/>
                            <Button Grid.Column="1" Content="×" Width="20" Height="20" FontSize="18" Margin="0,0,0,5"
                                    Click="CreateExpressionInputCancel_Click"
                                    Style="{StaticResource IconButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 生活杂务 -->
                <Border Grid.Row="1" Grid.Column="0" Background="#D6F3ED" Margin="8" MouseDown="LifeChoresBorder_MouseDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="生活杂务" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[2].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- 新任务输入框（可见性绑定） -->
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[2].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Modules[2].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="NewTaskTextBox_KeyDown"
                                     Tag="{Binding Modules[2]}"
                                     Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="×" Width="20" Height="20" FontSize="18" Margin="0,0,0,5"
                                    Click="LifeChoresInputCancel_Click"
                                    Style="{StaticResource IconButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 人际连接 -->
                <Border Grid.Row="1" Grid.Column="1" Background="#D6F3ED" Margin="8" MouseDown="InterpersonalConnectionBorder_MouseDown">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="人际连接" FontSize="20" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
                        <ListView Grid.Row="1" ItemsSource="{Binding Modules[3].Tasks}" Margin="10,10,10,0" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="FontSize" Value="18"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- 新任务输入框（可见性绑定） -->
                        <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" Visibility="{Binding Modules[3].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Modules[3].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="NewTaskTextBox_KeyDown"
                                     Tag="{Binding Modules[3]}"
                                     Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="×" Width="20" Height="20" FontSize="18" Margin="0,0,0,5"
                                    Click="InterpersonalConnectionInputCancel_Click"
                                    Style="{StaticResource IconButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <!-- 右侧板块 -->
        <StackPanel Grid.Column="1" Margin="0,20,30,20">
            <!-- 长期备忘 -->
            <!-- 右侧板块的长期备忘模块 -->
            <Border Background="#D6F3ED" Margin="0,0,0,16" Padding="16" MinHeight="200" Height="335"
        MouseDown="LongTermMemoBorder_MouseDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <TextBlock FontSize="20" FontWeight="Bold" Text="&#x9;     长期备忘" />

                    <!-- 任务列表（包含间距调整） -->
                    <ListView Grid.Row="1" ItemsSource="{Binding Modules[4].Tasks}" 
                  Margin="10,5,10,10" Background="Transparent" BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,5"/>
                                <!-- 上下间距5像素 -->
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- CheckBox -->
                                    <CheckBox Grid.Column="0" 
                                         IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                          VerticalAlignment="Center"/>

                                    <!-- 显示模式（默认） -->
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,0" VerticalAlignment="Center"
                     >
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>


                                    <!-- 编辑模式（悬停时显示） -->
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                     Margin="0,0,0,0" VerticalAlignment="Center"
                     KeyDown="TaskNameTextBox_KeyDown"/>

                                    <!-- 删除按钮 -->
                                    <Button Grid.Column="2" Content="×" Width="20" Height="20" Margin="10,0,0,0"
                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                    CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="FontSize" Value="18"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- 悬停时显示编辑提示 -->
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="ToolTip" Value="双击编辑"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 输入框（绑定长期备忘模块的可见性） -->
                    <Grid Grid.Row="1" Margin="10,0,10,10" VerticalAlignment="Bottom" 
              Visibility="{Binding Modules[4].IsInputVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Modules[4].NewTaskText, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="NewTaskTextBox_KeyDown"
                     Tag="{Binding Modules[4]}"
                     Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="×" Width="20" Height="20" FontSize="18" Margin="0,0,0,5"
                    Click="LongTermMemoInputCancel_Click"
                    Style="{StaticResource IconButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
            <!-- 本周复盘 -->
            <Border Background="#D6F3ED" Padding="16" MinHeight="200" Height="278">
                <TextBlock FontSize="20" FontWeight="Bold" Height="255" Text="&#x9;     本周复盘" />
            </Border>
        </StackPanel>
    </Grid>
</ui:Page>