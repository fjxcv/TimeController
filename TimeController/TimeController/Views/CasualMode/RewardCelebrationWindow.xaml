<Window x:Class="TimeController.Views.CasualMode.RewardCelebrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uiControls="clr-namespace:iNKORE.UI.WPF.Modern.Controls;assembly=iNKORE.UI.WPF.Modern"
        xmlns:vm="clr-namespace:TimeController.ViewModels"
        xmlns:converters="clr-namespace:TimeController.Converters"
        
        mc:Ignorable="d"
        Title="奖励时刻" Height="350" Width="400" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 圆角按钮样式 -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                              Background="{TemplateBinding Background}"
                              CornerRadius="8"
                              BorderThickness="0">
                            <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RewardPopupStyle" TargetType="Popup">
            <Setter Property="AllowsTransparency" Value="True"/>
            <Setter Property="PopupAnimation" Value="Fade"/>
        </Style>
        
        <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
        
    </Window.Resources>

    <Grid>
        <!-- 全屏烟花画布 -->
        <Canvas x:Name="FullScreenFireworksCanvas"
                Background="Transparent"
                IsHitTestVisible="False"/>

        <!-- 奖励弹窗 Border -->
        <Border CornerRadius="20"
                Background="#E6F2ED"
                BorderThickness="1"
                BorderBrush="#B2D8C8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0"
                       Width="50" Height="50"
                       Margin="0,20,0,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Stretch"
                       Source="pack://application:,,,/TimeController;component/Resources/fire1.png"
                       Stretch="Uniform"/>

                <TextBlock Grid.Row="1"
                           Text="恭喜你！进度条已满，专属奖励等你领取~"
                           FontSize="28"
                           Padding="15"
                           FontFamily="{StaticResource HOS_Sans_Bold}"
                           Foreground="#2E8B57"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,0"
                           Grid.RowSpan="2"/>

                <TextBlock Grid.Row="3"
                           Text="满格背后是一周的坚持，快来领奖！"
                           FontSize="14"
                           Foreground="#696969"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,0"/>

                <!-- 1. 奖励展示或选择区域 -->
                <Grid Grid.Row="4">
                    <!-- 领取按钮：继承 RoundedButtonStyle 并添加可见性触发器 -->
                    <Button x:Name="RewardButton"
                              Width="200" Height="50"
                              Margin="0,0,0,20"
                              HorizontalAlignment="Center"
                              Background="#B2D8C8"
                              Command="{Binding OpenRewardPopupCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
                                <!-- 默认显示 -->
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- 没有选中奖励时隐藏按钮 -->
                                    <DataTrigger Binding="{Binding FinalRewardTask}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Image Source="pack://application:,,,/TimeController;component/Resources/reward.png"
             Width="24" Height="24" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding FinalRewardTask.Title}"
                                         FontSize="20"
                                         FontWeight="SemiBold"
                                         Foreground="#2E8B57"/>
                        </StackPanel>
                    </Button>

                    <!-- 下拉列表：继承默认 ComboBox Style 并添加可见性触发器 -->
                    <ComboBox x:Name="RewardComboBox"
                                ItemsSource="{Binding RewardTasks}"
                                DisplayMemberPath="Title"
                                SelectedItem="{Binding FinalRewardTask, Mode=TwoWay}"
                                Width="200" Height="50"
                                Margin="0,0,0,20"
                                HorizontalAlignment="Center">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <!-- 默认隐藏 -->
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <!-- 没有选中奖励时显示下拉 -->
                                    <DataTrigger Binding="{Binding FinalRewardTask}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>




                <!-- 2. 奖励选择弹窗 -->
                <Popup x:Name="RewardPopup"
                       Style="{StaticResource RewardPopupStyle}"
                       IsOpen="{Binding IsRewardPopupOpen, Mode=TwoWay}"
                       StaysOpen="False"
                       Focusable="True"
                       FocusManager.IsFocusScope="True"
                       HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              CornerRadius="8"
                              Width="320" Height="360">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- 标题 -->
                                <RowDefinition Height="*"/>
                                <!-- 列表 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 新增输入 -->
                                <RowDefinition Height="Auto"/>
                                <!-- 确认/取消 -->
                            </Grid.RowDefinitions>

                            <!-- 标题 -->
                            <TextBlock Grid.Row="0"
                                     Text="请选择本周奖励"
                                     FontSize="16" FontFamily="{StaticResource HOS_Sans_Bold}"
                                     Margin="4"/>

                            <!-- 单选 ListView -->
                            <ListView Grid.Row="1"
                                        ItemsSource="{Binding RewardTasks}"
                                        SelectedItem="{Binding TempSelectedRewardTask}"
                                        Margin="0,8"
                                        SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}"
                                                   Padding="6"
                                                   FontSize="14"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- 新增一行 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8">
                                <Grid Width="200" Height="28">
                                    <!-- 真正的 TextBox -->
                                    <TextBox x:Name="RewardTaskInput"
                                               Text="{Binding NewRewardTaskText, UpdateSourceTrigger=PropertyChanged}"
                                               Background="Transparent"
                                               BorderBrush="#E0E0E0"
                                               Padding="4"/>

                                    <!-- 占位提示用的 TextBlock，TextBox 为空时显示 -->
                                    <TextBlock Text="输入新奖励，按回车添加"
                                                 Foreground="#AAA"
                                                 Margin="6,0,0,0"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- Text 为空 或 Null 时显示 -->
                                                    <DataTrigger Binding="{Binding Text, ElementName=RewardTaskInput}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Text, ElementName=RewardTaskInput}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- 确认 / 取消 -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <Button Content="取消"
                                        Width="80" Margin="0,0,12,0"
                                        Command="{Binding CloseRewardPopupCommand}"/>
                                <Button Content="确认"
                                        Width="80"
                                        IsEnabled="{Binding TempSelectedRewardTask, Converter={StaticResource NotNullToBoolConverter}}"
                                        Command="{Binding ConfirmRewardSelectionCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Popup>
                
                <!-- 领取按钮 -->
                <Button x:Name="ClaimRewardButton"
                        Grid.Row="5"
                        Content="立即领取"
                        Width="130"
                        Height="40"
                        FontSize="16"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Background="#6A9DD1"
                        Foreground="White"
                        Style="{StaticResource RoundedButtonStyle}"
                        Click="ClaimRewardButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>