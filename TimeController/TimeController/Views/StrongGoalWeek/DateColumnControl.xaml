            <!-- 全天任务列表 -->
            <ItemsControl Grid.Row="1" Margin="2,2,2,2" 
                          ItemsSource="{Binding AllDayTasksView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave" MouseLeftButtonDown="TaskBlock_MouseLeftButtonDown"
                                Background="Transparent" Tag="{Binding}">
                            <!-- 任务块背景 -->
                            <Border Background="{Binding Brush}"
                                    CornerRadius="3"
                                    Margin="2">
                                <TextBlock Text="{Binding Name}"
                                             Margin="8,4"
                                           TextWrapping="Wrap"
                                           Foreground="#333333"
                                           FontWeight="Medium"
                                           TextDecorations="{Binding Status, Converter={StaticResource CompletedToTextDecorationConverter}}">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Note}" FontStyle="Italic" Foreground="#666666" TextWrapping="Wrap" MaxWidth="200"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Border>

                            <!-- 浮动按钮组 -->
                            <StackPanel x:Name="ActionButtons"
                                        Panel.ZIndex="10"            
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="4"
                                        Visibility="Collapsed">
                                <!-- 标记完成 -->
                                <Button Width="19" Height="19"
                                          Padding="0"
                                          Background="#CCFFFFFF"
                                          BorderThickness="0"
                                          Margin="4,0,5,0"
                                          Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                          CommandParameter="{Binding}">
                                    <TextBlock 
                                          FontFamily="Segoe MDL2 Assets" 
                                          Text="&#xE73E;"
                                          FontSize="20" 
                                          Foreground="#333333"/>
                                </Button>

                                <!-- 删除任务 -->
                                <Button Width="19" Height="19"
                                          Padding="0"
                                          Background="#CCFFFFFF"
                                          BorderThickness="0"
                                          Command="{Binding DataContext.RemoveTaskBlockCommand,
                                                    RelativeSource={RelativeSource AncestorType=ui:Page}}"
                                          CommandParameter="{Binding}">
                                    <TextBlock 
                                          FontFamily="Segoe MDL2 Assets" 
                                          Text="&#xE74D;"
                                          FontSize="20" 
                                          Foreground="#333333"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <!-- 第三个及以上的任务只有在展开状态下才显示 -->
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                         Converter={StaticResource IndexConverter}, ConverterParameter=gt1}" 
                         Value="True">
                                <Setter Property="Visibility" Value="{Binding DataContext.IsExpanded, 
                         RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, 
                         Converter={StaticResource BoolToVisibility}}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>

            <!-- 展开/折叠按钮 -->
            <Button x:Name="ExpandButton" Grid.Row="1" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,2,0,0"
                    Click="ExpandButton_Click"
