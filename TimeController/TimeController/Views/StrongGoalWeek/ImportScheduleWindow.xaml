<Window x:Class="TimeController.Views.StrongGoalWeek.ImportScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeController.Views.StrongGoalWeek"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        mc:Ignorable="d"
        Title="ImportScheduleWindow" Height="450" Width="800">
    <StackPanel Margin="20">

        <!-- 导入面板 -->
        <StackPanel x:Name="ImportPanel">
            <TextBlock Text="请粘贴你的教务系统课表页面链接或源码：" Margin="0,10,0,10"/>
            <TextBox x:Name="InputBox" Height="75" AcceptsReturn="True" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="教务导入" Width="80" Margin="0,0,10,0" Click="Import_Click"/>
                <Button x:Name="DownloadButton"
                    Content="文件导入"
                    Width="80"
                    Click="Download_Click"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
