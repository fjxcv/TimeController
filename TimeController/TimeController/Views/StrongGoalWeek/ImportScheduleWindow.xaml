<Window x:Class="TimeController.Views.StrongGoalWeek.ImportScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        Title="导入课表" Height="200" Width="350" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">

        <!-- 导入面板 -->
        <StackPanel x:Name="ImportPanel">
            <TextBlock Text="请选择导入方式" Margin="0,20,0,30" HorizontalAlignment="Center"  FontSize="16"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="教务导入" Command="{Binding ImportFromUrlCommand}" Width="100" Margin="0,0,10,0"/>
                <Button Content="文件导入" Command="{Binding ImportFromFileCommand}" Width="100"/>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>