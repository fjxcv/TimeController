                    <TextBlock Text="全天任务" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="0:00" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="1:00" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="2:00" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="3:00" Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="4:00" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="5:00" Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="6:00" Grid.Row="7" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="7:00" Grid.Row="8" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="8:00" Grid.Row="9" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="9:00" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="10:00" Grid.Row="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="11:00" Grid.Row="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="12:00" Grid.Row="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="13:00" Grid.Row="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="14:00" Grid.Row="15" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="15:00" Grid.Row="16" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="16:00" Grid.Row="17" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="17:00" Grid.Row="18" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="18:00" Grid.Row="19" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="19:00" Grid.Row="20" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="20:00" Grid.Row="21" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="21:00" Grid.Row="22" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="22:00" Grid.Row="23" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock Text="23:00" Grid.Row="24" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </Grid>

