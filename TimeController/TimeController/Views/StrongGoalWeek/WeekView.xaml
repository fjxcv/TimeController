                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
