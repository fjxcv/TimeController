<ui:Page x:Class="TimeController.Views.StrongGoalWeek.WeekView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:TimeController.Views.StrongGoalWeek"
        xmlns:conv="clr-namespace:TimeController.Converters"

        mc:Ignorable="d" 
        Title="" d:DesignHeight="800" d:DesignWidth="1104">

    <ui:Page.Resources>
        <conv:CompletedToTextDecorationConverter x:Key="CompletedToTextDecorationConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </ui:Page.Resources>

    <Grid x:Name="RootGrid" PreviewMouseLeftButtonDown="RootGrid_PreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,0,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="强目标模式"
                       FontSize="24"
                       FontFamily="{StaticResource HOS_Sans_Bold}"
                       VerticalAlignment="Center"/>

            <!-- 将月份日期的显示移到中间位置 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="&lt;" Margin="8,0" Padding="8,4" Command="{Binding PreviousMonthCommand}"/>
                <TextBlock x:Name="MonthText" Text="{Binding MonthText}" VerticalAlignment="Center" Margin="8,0" FontSize="16"/>
                <Button Content="&gt;" Margin="8,0" Padding="8,4" Command="{Binding NextMonthCommand}"/>
                <Button Content="&lt;" Margin="24,0,8,0" Padding="8,4" Command="{Binding PreviousWeekCommand}"/>
                <TextBlock x:Name="WeekText" Text="{Binding WeekText}" VerticalAlignment="Center" Margin="8,0"  FontSize="16"/>
                <Button Content="&gt;" Margin="8,0" Padding="8,4" Command="{Binding NextWeekCommand}"/>

                <TextBlock Text="{Binding SemesterWeekText}" 
                   VerticalAlignment="Center" 
                   Margin="24,0,8,0"
                   Foreground="#0078D4"
                   FontSize="13"
                   FontFamily="{StaticResource HOS_Sans_Bold}"
                   Visibility="Visible"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="导入课表" 
                    Margin="0,0,16,0"
                    Padding="16,8"
                    Click="ImportSchedule_Click"/>

            <Button Grid.Column="3"
                    Content="进入复盘"
                    Command="{Binding ReviewCommand}"
                    Padding="16,8"/>
        </Grid>

        <Button Grid.Column="4"
                    Content="📍 今天"
                    Padding="8,4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="420,0,0,0"
                    Click="TodayButton_Click"/>
            
        <!-- 内容区 - 采用新布局 -->
        <Grid Grid.Row="2" Margin="24,24,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 日期行 -->
                <RowDefinition Height="Auto"/> 
                <!-- 全天任务行（固定区域） -->
                <RowDefinition Height="*"/>
                <!-- 时间任务区（可滚动区域） -->
            </Grid.RowDefinitions>

            <!-- 日期行 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="75"/>
                    <!-- 左侧时间轴区域 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 日期显示区域 -->
                </Grid.ColumnDefinitions>

                <!-- 左上角区域显示"全天任务" -->
                <Border Grid.Column="0" Background="Transparent">
                    <TextBlock Text="全天任务" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               FontSize="14"
                               Foreground="#333333"/>
                </Border>

                <!-- 日期列标题 -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 使用自定义控件显示日期 -->
                    <local:DateColumnControl x:Name="DateColumn0" Grid.Column="0" DataContext="{Binding DateColumns[0]}"/>
                    <local:DateColumnControl x:Name="DateColumn1" Grid.Column="1" DataContext="{Binding DateColumns[1]}"/>
                    <local:DateColumnControl x:Name="DateColumn2" Grid.Column="2" DataContext="{Binding DateColumns[2]}"/>
                    <local:DateColumnControl x:Name="DateColumn3" Grid.Column="3" DataContext="{Binding DateColumns[3]}"/>
                    <local:DateColumnControl x:Name="DateColumn4" Grid.Column="4" DataContext="{Binding DateColumns[4]}"/>
                    <local:DateColumnControl x:Name="DateColumn5" Grid.Column="5" DataContext="{Binding DateColumns[5]}"/>
                    <local:DateColumnControl x:Name="DateColumn6" Grid.Column="6" DataContext="{Binding DateColumns[6]}"/>
                </Grid>
            </Grid>

            <!-- 时间任务区（可滚动区域） -->
            <ScrollViewer Grid.Row="2" x:Name="TimeTasksScrollViewer" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="WeekContentGrid" Background="Transparent" MouseLeftButtonDown="WeekContentGrid_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <!-- 左侧时间轴区域 -->
                        <ColumnDefinition Width="*"/>
                        <!-- 时间任务区域 -->
                    </Grid.ColumnDefinitions>

                    <!-- 时间轴 -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="0:00" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="1:00" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="2:00" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="3:00" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="4:00" Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="5:00" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="6:00" Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="7:00" Grid.Row="7" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="8:00" Grid.Row="8" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="9:00" Grid.Row="9" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="10:00" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="11:00" Grid.Row="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="12:00" Grid.Row="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="13:00" Grid.Row="13" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="14:00" Grid.Row="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="15:00" Grid.Row="15" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="16:00" Grid.Row="16" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="17:00" Grid.Row="17" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="18:00" Grid.Row="18" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="19:00" Grid.Row="19" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="20:00" Grid.Row="20" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="21:00" Grid.Row="21" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="22:00" Grid.Row="22" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="23:00" Grid.Row="23" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock Text="24:00" Grid.Row="24" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- 时间任务区域 -->
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 背景高亮层 -->
                        <Border x:Name="TaskColumn0" Grid.Column="0" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="0"/>
                        <Border x:Name="TaskColumn1" Grid.Column="1" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="1"/>
                        <Border x:Name="TaskColumn2" Grid.Column="2" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="2"/>
                        <Border x:Name="TaskColumn3" Grid.Column="3" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="3"/>
                        <Border x:Name="TaskColumn4" Grid.Column="4" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="4"/>
                        <Border x:Name="TaskColumn5" Grid.Column="5" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="5"/>
                        <Border x:Name="TaskColumn6" Grid.Column="6" Background="Transparent"
                                MouseLeftButtonDown="TaskColumn_MouseLeftButtonDown" Tag="6"/>


                        <!-- 课程显示区域 -->
                        <ItemsControl Grid.ColumnSpan="7" ItemsSource="{Binding CourseTaskBlocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <!-- 0:00到24:00，每小时一行 -->
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                    </Grid>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Grid.Column" Value="{Binding Column}" />
                                    <Setter Property="Grid.Row" Value="{Binding Row}" />
                                    <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave" MouseLeftButtonDown="TaskBlock_MouseLeftButtonDown"
                                          Background="Transparent" Tag="{Binding}">
                                        <Border Background="#E6F7FF" BorderBrush="#1890FF" BorderThickness="1" CornerRadius="3" Margin="2">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- 课程名称和时间 -->
                                                <StackPanel Grid.Row="0" Orientation="Vertical">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="{StaticResource HOS_Sans_Bold}" Margin="5,3,5,1"
                                                               TextWrapping="Wrap"
                                                               Foreground="#0078D4"/>
                                                    <TextBlock Margin="5,0,5,2"  FontSize="11" Foreground="#333333">
                                                        <Run Text="{Binding StartTime, Converter={StaticResource TimeSpanToStringConverter}}"/>
                                                        <Run Text=" - "/>
                                                        <Run Text="{Binding EndTime, Converter={StaticResource TimeSpanToStringConverter}}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- 教师和教室信息 -->
                                                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="5,0,5,3">
                                                    <TextBlock FontSize="11" TextWrapping="Wrap">
                                                        <Run Text="教师: "/>
                                                        <Run Text="{Binding Note, Converter={StaticResource NoteToTeacherConverter}}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" TextWrapping="Wrap">
                                                        <Run Text="教室: "/>
                                                        <Run Text="{Binding Note, Converter={StaticResource NoteToLocationConverter}}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <StackPanel x:Name="ActionButtons" Panel.ZIndex="10" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4" Visibility="Collapsed">
                                            <Button Width="26" Height="26" Padding="0" Background="#CCFFFFFF" BorderThickness="0"
                                                    Command="{Binding DataContext.RemoveTaskBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="20" Foreground="#333333"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 分时任务区域 -->
                        <ItemsControl Grid.ColumnSpan="7" ItemsSource="{Binding TimedTaskBlocksView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                    </Grid>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Grid.Column" Value="{Binding Column}" />
                                    <Setter Property="Grid.Row" Value="{Binding Row}" />
                                    <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid MouseEnter="Grid_MouseEnter" MouseLeave="Grid_MouseLeave" MouseLeftButtonDown="TaskBlock_MouseLeftButtonDown"
                                        Background="Transparent" Tag="{Binding}">
                                        <!-- 任务块背景 -->
                                        <Border Background="{Binding Brush}"
                                                CornerRadius="3"
                                                Margin="2">
                                            <TextBlock Text="{Binding Name}"
                                                     Margin="8,4,8,4"
                                                     TextTrimming="CharacterEllipsis"
                                                     TextWrapping="NoWrap"
                                                     Foreground="#333333"
                                                     FontFamily="{StaticResource HOS_Sans_Medium}"
                                                     TextDecorations="{Binding Status, Converter={StaticResource CompletedToTextDecorationConverter}}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip>
                                                        <StackPanel>
                                                            <!-- 名称 -->
                                                            <TextBlock Text="{Binding Name}" 
                                                                       FontFamily="{StaticResource HOS_Sans_Bold}" 
                                                                       Margin="0,0,0,4"/>
                                                            <!-- 时间段 -->
                                                            <TextBlock FontSize="12"
                                                                       Foreground="#666666"
                                                                       Margin="0,0,0,4">
                                                                <Run Text="{Binding StartTime, Converter={StaticResource TimeSpanToStringConverter}}"/>
                                                                <Run Text=" – "/>
                                                                <Run Text="{Binding EndTime, Converter={StaticResource TimeSpanToStringConverter}}"/>
                                                            </TextBlock>
                                                            <!-- 备注（如果为空就不显示也没关系） -->
                                                            <TextBlock Text="{Binding Note}" 
                                                                       FontStyle="Italic" 
                                                                       Foreground="#666666" 
                                                                       TextWrapping="Wrap" 
                                                                       MaxWidth="200"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                                </TextBlock>
                                        </Border>

                                        <!-- 浮动按钮组 -->
                                        <StackPanel x:Name="ActionButtons"
                                                    Panel.ZIndex="10"            
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="4"
                                                    Visibility="Collapsed">
                                            <!-- 标记完成 -->
                                            <Button Width="26" Height="26"
                                                  Padding="0"
                                                  Background="#CCFFFFFF"
                                                  BorderThickness="0"
                                                  Margin="4,0,5,0"
                                                  Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}">
                                                <TextBlock 
                                                  FontFamily="Segoe MDL2 Assets" 
                                                  Text="&#xE73E;"
                                                  FontSize="20" 
                                                  Foreground="#333333"/>
                                            </Button>

                                            <!-- 删除任务 -->
                                            <Button Width="26" Height="26"
                                                      Padding="0"
                                                      Background="#CCFFFFFF"
                                                      BorderThickness="0"
                                                      Command="{Binding DataContext.RemoveTaskBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}">
                                                <TextBlock 
                                                  FontFamily="Segoe MDL2 Assets" 
                                                  Text="&#xE74D;"
                                                  FontSize="20" 
                                                  Foreground="#333333"/>
                                              </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 添加按钮Canvas -->
        <Canvas x:Name="RootCanvas">
            <Button x:Name="AddTaskButton"
                    Content="＋"
                    Width="40" Height="40"
                    Visibility="Collapsed"
                    Click="AddTaskButton_Click"/>
            <Border x:Name="TaskDetailsCard" Visibility="Collapsed" 
                    Background="#fffbc7" CornerRadius="4" Padding="3"
                    BorderBrush="#fffbc7" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="CardNoteText" TextWrapping="Wrap" Margin="0,0,0,2" FontSize="13"/>
                    <TextBlock x:Name="CardTypeText" Margin="0,0,0,2" FontSize="13"/>
                    <TextBlock x:Name="CardTimeText" FontSize="13"/>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</ui:Page>
