                        <RowDefinition Height="40"/>
                        <!-- 0:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 1:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 2:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 3:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 4:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 5:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 6:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 7:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 8:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 9:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 10:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 11:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 12:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 13:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 14:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 15:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 16:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 17:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 18:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 19:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 20:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 21:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 22:00 -->
                        <RowDefinition Height="40"/>
                        <!-- 23:00 -->
