<Window x:Class="TimeController.Views.StrongGoalWeek.AddCourseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:WindowHelper.SystemBackdropType="Mica"
        Title="添加课程" Height="510" Width="400"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<!-- 课程名称 -->
				<TextBlock Text="课程名称:"
                           Margin="0,5,0,2"
                           FontWeight="Medium"/>
				<TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10" 
						 Width="270"
						 HorizontalAlignment="Left"/>

				<!-- 星期几 -->
				<TextBlock Text="课程日:"
                           Margin="0,5,0,2"
                           FontWeight="Medium"/>
				<ComboBox SelectedValue="{Binding DayOfWeek}"
                          SelectedValuePath="Tag"
                          Margin="0,0,0,10" 
						  HorizontalAlignment="Left">
					<ComboBoxItem Content="周一" Tag="一"/>
					<ComboBoxItem Content="周二" Tag="二"/>
					<ComboBoxItem Content="周三" Tag="三"/>
					<ComboBoxItem Content="周四" Tag="四"/>
					<ComboBoxItem Content="周五" Tag="五"/>
					<ComboBoxItem Content="周六" Tag="六"/>
					<ComboBoxItem Content="周日" Tag="日"/>
				</ComboBox>

				<!-- 时间选择器 -->
				<TextBlock Text="课程时间:"
                           Margin="0,5,0,2"
                           FontWeight="Medium"/>
				<Grid Margin="0,0,0,10" Width="270" HorizontalAlignment="Left">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<!-- 开始时间 -->
						<RowDefinition Height="Auto"/>
						<!-- 横线 -->
						<RowDefinition Height="Auto"/>
						<!-- 结束时间 -->
						<RowDefinition Height="Auto"/>
						<!-- 错误提示 -->
					</Grid.RowDefinitions>

					<!-- 开始时间 -->
					<ui:TimePicker Grid.Row="0"
								   SelectedDateTime="{Binding StartTimeWrapper, Mode=TwoWay}"
								   HorizontalAlignment="Stretch"/>

					<!-- 中间的横线，居中显示 -->
					<TextBlock Grid.Row="1"
							   Text="—"
							   FontSize="18"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   Margin="0,5"/>

					<!-- 结束时间 -->
					<ui:TimePicker Grid.Row="2"
								   SelectedDateTime="{Binding EndTimeWrapper, Mode=TwoWay}"
								   HorizontalAlignment="Stretch"/>

					<!-- 时间错误提示 -->
					<TextBlock Grid.Row="3"
							   Text="{Binding TimeError}"
							   Foreground="Red"
							   FontSize="12"
							   Margin="0,4,0,0"
							   Visibility="{Binding HasTimeError, Converter={StaticResource BoolToVisibility}}"/>
				</Grid>

				<!-- 上课地点 -->
				<TextBlock Text="上课地点:"
                           Margin="0,5,0,2"
                           FontWeight="Medium"/>
				<TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
						 Width="270"
						 HorizontalAlignment="Left"
						 />

				<!-- 教师姓名 -->
				<TextBlock Text="授课老师:"
                           Margin="0,5,0,2"
                           FontWeight="Medium"/>
				<TextBox Text="{Binding Teacher, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
						 Width="270"
						 HorizontalAlignment="Left"
						 />
			</StackPanel>
		</ScrollViewer>

		<Grid Grid.Row="2" Margin="0,15,0,0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Button Grid.Column="1" Content="取消"
                    Margin="0,0,10,0" Padding="15,5"
                    Click="CancelButton_Click"/>
			<Button Grid.Column="2" Content="添加"
                    Padding="15,5" Click="AddButton_Click"
                    IsDefault="True"
                    IsEnabled="{Binding IsTimeValid}"/>
		</Grid>
	</Grid>
</Window>
