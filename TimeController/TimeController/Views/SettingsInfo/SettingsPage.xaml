<ui:Page x:Class="TimeController.Views.SettingsInfo.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
             xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
            xmlns:local="clr-namespace:TimeController.Services"

>

    <ui:Page.Resources>
        <!-- 基于系统 AccentButtonStyleKey 创建一个自定义保存按钮样式 -->
        <Style x:Key="SaveButtonStyle"
         TargetType="Button"
         BasedOn="{StaticResource {x:Static ui:ThemeKeys.AccentButtonStyleKey}}">
            <!-- 默认文字色保持白色 -->
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <!-- 鼠标移入时，背景会变浅，我们把文字改成深色 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <!-- 如果还想在按下时再调一次样式 -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:Page.Resources>
    <ScrollViewer>
    <ikw:SimpleStackPanel Spacing="6" Margin="0,20,0,0">

        <!-- 每周目标任务量 -->
        <ui:SettingsCard Header="【咸鱼】每周目标任务量"
                         Description="设置您希望咸鱼模式每周完成的任务数量。"
                         IsEnabled="True">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE8EC;"/>
                <!-- 可换成喜欢的图标 -->
            </ui:SettingsCard.HeaderIcon>
                <ui:NumberBox   MinWidth="60"
                                Maximum="20" Minimum="4"
                                PlaceholderText="输入大于4的整数"
                                SpinButtonPlacementMode="Inline" 
                                ValidationMode="InvalidInputOverwritten"
                                IsWrapEnabled="False"
                                AcceptsExpression="False"
                                CornerRadius="4,4,4,4"
                                Value="{Binding RewardThreshold, Mode=TwoWay}"/>

            </ui:SettingsCard>

            <!-- 主题设置卡片 --><!--
            <ui:SettingsCard Header="主题模式"
                 Description="选择浅色 / 深色，或跟随系统"
                 IsEnabled="True">
                <ui:SettingsCard.HeaderIcon>
                    <ui:FontIcon Glyph="&#xE765;" FontSize="20"/>
                </ui:SettingsCard.HeaderIcon>

                <ComboBox Width="60"
                        SelectedValue="{Binding SelectedThemeOption}"
                        SelectedValuePath="Tag"
                        Margin="0,8,0,0">
                    <ComboBoxItem Content="Light"    Tag="{x:Static local:ThemeOption.Light}"   />
                    <ComboBoxItem Content="Dark"     Tag="{x:Static local:ThemeOption.Dark}"    />
                    <ComboBoxItem Content="跟随系统" Tag="{x:Static local:ThemeOption.System}"  />
                </ComboBox>
            </ui:SettingsCard>-->

            <!-- 保存 & 重置 按钮 -->
            <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          Margin="0,16,0,0">
                <!-- 重置：普通按钮 -->
                <Button Content="重置"
                        MinWidth="70"
                        MinHeight="35"
                        Command="{Binding ResetCommand}"
                        Margin="0,0,0,0"/>

                <!-- 保存：Accent 风格按钮 -->
                <Button Content="保存"
                        Command="{Binding SaveCommand}"
                        MinWidth="70"
                        MinHeight="35"
                        Margin="20,0,30,0"
                        Style="{StaticResource SaveButtonStyle}" />
            </StackPanel>
        
        </ikw:SimpleStackPanel>
</ScrollViewer>

</ui:Page>