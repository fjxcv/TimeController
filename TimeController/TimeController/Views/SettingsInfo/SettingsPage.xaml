<ui:Page x:Class="TimeController.Views.SettingsInfo.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" 
             xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
>

<ScrollViewer>
    <ikw:SimpleStackPanel Spacing="4">

        <!-- 每周目标任务量 -->
        <ui:SettingsCard Header="每周目标任务量"
                         Description="设置您希望每周完成的任务数量。"
                         IsEnabled="True">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE8EC;"/>
                <!-- 可换成喜欢的图标 -->
            </ui:SettingsCard.HeaderIcon>
                <ui:NumberBox   MinWidth="60"
                                Maximum="20" Minimum="4"
                                PlaceholderText="输入大于4的整数"
                                SpinButtonPlacementMode="Inline" 
                                ValidationMode="InvalidInputOverwritten"
                                IsWrapEnabled="False"
                                AcceptsExpression="False"
                                CornerRadius="4,4,4,4"
                                Value="{Binding RewardThreshold, Mode=TwoWay}"/>

            </ui:SettingsCard>

        <!-- 跟随系统主题 -->
        <ui:SettingsCard Header="跟随系统主题"
                         Description="开启后，应用将自动跟随操作系统的浅/深色模式切换。"
                         IsEnabled="True">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Glyph="&#xE706;"/>
            </ui:SettingsCard.HeaderIcon>
            <ui:ToggleSwitch IsOn="{Binding FollowSystemTheme, Mode=TwoWay}"
                           OnContent="开启" OffContent="关闭"/>
        </ui:SettingsCard>

    </ikw:SimpleStackPanel>
</ScrollViewer>

</ui:Page>